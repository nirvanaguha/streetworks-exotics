---
import Layout from "../../layouts/Layout.astro";
import servicesData from "../../data/services.json";
import Navbar from "../../components/NavBar.astro";
import ServiceHero from "../../components/ServiceHero.astro";
import ServiceGallery from "../../components/ServiceGallery.astro";
import ReviewsSection from "../../components/ReviewsSection.astro";
import ContactSection from "../../components/ContactSection.astro";
import TextReveal from "../../components/TextReveal.astro";
import Footer from "../../components/Footer.astro";

export async function getStaticPaths() {
    return servicesData.map((service: any) => {
        return {
            params: { slug: service.slug },
            props: { service },
        };
    });
}

const { service } = Astro.props;
---

<Layout title={`${service.title} | StreetWorks Exotics`}>
    <Navbar />

    <main class="relative w-full bg-black text-white">
        <div class="service-hero-wrapper relative z-10">
            <ServiceHero
                title={service.title}
                tagline={service.heroTagline}
                bgImgUrl={service.heroImage}
                tintColor={service.tintColor}
                deepTextTitle={service.deepTextTitle}
                deepTextParagraphs={service.deepTextParagraphs}
            />
        </div>

        <div class="relative z-20 bg-[#050505]">
            <ServiceGallery images={service.galleryImages} />
        </div>

        {
            service.midText && (
                <div
                    id="mid-text-container"
                    class="relative w-full h-[350dvh] bg-[#050505] z-10 -mt-[100dvh]"
                >
                    <div class="sticky top-0 w-full h-[100dvh] overflow-hidden z-10 flex items-center justify-center">
                        <div
                            id="mid-text-layer"
                            class="absolute inset-0 z-30 opacity-0 invisible flex flex-col items-center justify-center pointer-events-none"
                        >
                            <TextReveal
                                id="mid-text-reveal"
                                text={service.midText}
                                gradientFrom="#ffffff"
                                gradientTo="#94a3b8"
                            />
                        </div>
                    </div>
                </div>
            )
        }

        <div class="relative z-20 bg-black -mt-[100dvh]">
            <ReviewsSection />
        </div>

        {
            service.finalText && (
                <div
                    id="final-text-container"
                    class="relative w-full h-[350dvh] bg-black z-10 -mt-[100dvh]"
                >
                    <div class="sticky top-0 w-full h-[100dvh] overflow-hidden z-10 flex items-center justify-center">
                        <div
                            id="final-text-layer"
                            class="absolute inset-0 z-30 opacity-0 invisible flex flex-col items-center justify-center pointer-events-none"
                        >
                            <TextReveal
                                id="final-text-reveal"
                                text={service.finalText}
                                gradientFrom="#ffffff"
                                gradientTo={service.tintColor}
                            />
                        </div>
                    </div>
                </div>
            )
        }

        <div class="relative z-20 bg-black -mt-[100dvh]">
            <ContactSection />
        </div>

        <Footer />
    </main>

    <script>
        import { gsap } from "gsap";
        import { ScrollTrigger } from "gsap/ScrollTrigger";

        gsap.registerPlugin(ScrollTrigger);

        // 1. HERO IMAGE PARALLAX
        gsap.to(".service-hero-wrapper img", {
            yPercent: 15,
            ease: "none",
            scrollTrigger: {
                trigger: ".service-hero-wrapper",
                start: "top top",
                end: "bottom top",
                scrub: true,
            },
        });

        // 2. MASONRY GALLERY PARALLAX
        let mm = gsap.matchMedia();
        mm.add("(min-width: 768px)", () => {
            gsap.to(".gallery-col-left", {
                y: 100,
                ease: "none",
                scrollTrigger: {
                    trigger: ".service-gallery-wrapper",
                    start: "top bottom",
                    end: "bottom top",
                    scrub: 1,
                },
            });
            gsap.to(".gallery-col-right", {
                y: -100,
                ease: "none",
                scrollTrigger: {
                    trigger: ".service-gallery-wrapper",
                    start: "top bottom",
                    end: "bottom top",
                    scrub: 1,
                },
            });
        });

        // 3. DEEP TEXT (HERO) REVEAL
        const deepText = document.getElementById("deep-text-reveal");
        if (deepText) {
            const words = deepText.querySelectorAll(".reveal-word");
            gsap.to(words, {
                opacity: 1,
                stagger: 0.05,
                ease: "none",
                scrollTrigger: {
                    trigger: deepText,
                    start: "top 85%",
                    end: "bottom 50%",
                    scrub: true,
                },
            });
            gsap.to(deepText, {
                backgroundPosition: "-200% 0%",
                ease: "none",
                scrollTrigger: {
                    trigger: deepText,
                    start: "top 85%",
                    end: "bottom 50%",
                    scrub: true,
                },
            });
        }

        // 4. MID TEXT TIMELINE (Perfected Fade from Black)
        const midContainer = document.getElementById("mid-text-container");
        if (midContainer) {
            const midTl = gsap.timeline({
                scrollTrigger: {
                    trigger: midContainer,
                    // Waits exactly 100vh for the Gallery (z-20) to slide off the screen before triggering
                    start: "100vh top",
                    end: "bottom bottom",
                    scrub: 1,
                },
            });

            midTl.to("#mid-text-layer", { autoAlpha: 1, duration: 0.1 }, 0);
            midTl.to(
                "#mid-text-reveal .reveal-word",
                {
                    opacity: 1,
                    duration: 0.6,
                    stagger: { amount: 0.6 },
                    ease: "power2.out",
                },
                0.1,
            );
            midTl.to(
                "#mid-text-reveal",
                { backgroundPosition: "-200% 0%", duration: 1.0, ease: "none" },
                0.1,
            );

            // Hold the fully lit text on the black screen
            midTl.to({}, { duration: 1.5 });

            // Fade the text cleanly out to black
            midTl.to("#mid-text-reveal", {
                autoAlpha: 0,
                scale: 0.95,
                duration: 0.6,
            });
            midTl.to("#mid-text-layer", { autoAlpha: 0, duration: 0.1 });

            // Crucial: A brief dead zone so the screen remains perfectly black as the Reviews section (z-20) starts sliding up
            midTl.to({}, { duration: 0.8 });
        }

        // 5. HORIZONTAL REVIEWS MATH
        const reviewsContainer = document.getElementById("reviews-container");
        const reviewsFadeLayer = document.getElementById("reviews-fade-layer");
        const reviewsTrack = document.getElementById("reviews-track");

        if (reviewsContainer && reviewsTrack && reviewsFadeLayer) {
            const reviewsTl = gsap.timeline({
                scrollTrigger: {
                    trigger: reviewsContainer,
                    start: "top top",
                    end: "bottom bottom",
                    scrub: 1,
                    invalidateOnRefresh: true,
                },
            });

            reviewsTl.to(reviewsFadeLayer, { autoAlpha: 1, duration: 0.5 });
            reviewsTl.to({}, { duration: 1.0 });
            reviewsTl.to(reviewsTrack, {
                x: () => "-100vw",
                duration: 2.0,
                ease: "none",
            });
            reviewsTl.to({}, { duration: 1.0 });
            reviewsTl.to(reviewsTrack, {
                x: () => "-200vw",
                duration: 2.0,
                ease: "none",
            });
            reviewsTl.to({}, { duration: 2.0 });
            reviewsTl.to(reviewsFadeLayer, { autoAlpha: 0, duration: 0.5 });
        }

        // 6. FINAL TEXT TIMELINE
        const finalContainer = document.getElementById("final-text-container");
        if (finalContainer) {
            const finalTl = gsap.timeline({
                scrollTrigger: {
                    trigger: finalContainer,
                    start: "100vh top",
                    end: "bottom bottom",
                    scrub: 1,
                },
            });

            finalTl.to("#final-text-layer", { autoAlpha: 1, duration: 0.1 }, 0);
            finalTl.to(
                "#final-text-reveal .reveal-word",
                {
                    opacity: 1,
                    duration: 0.6,
                    stagger: { amount: 0.6 },
                    ease: "power2.out",
                },
                0.1,
            );
            finalTl.to(
                "#final-text-reveal",
                { backgroundPosition: "-200% 0%", duration: 1.0, ease: "none" },
                0.1,
            );

            finalTl.to({}, { duration: 1.5 });

            finalTl.to("#final-text-reveal", {
                autoAlpha: 0,
                scale: 0.95,
                duration: 0.6,
            });
            finalTl.to("#final-text-layer", { autoAlpha: 0, duration: 0.1 });

            finalTl.to({}, { duration: 0.8 });
        }
    </script>
</Layout>
