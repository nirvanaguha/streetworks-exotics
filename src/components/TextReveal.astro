---
interface Props {
  id: string;
  gradientFrom?: string;
  gradientTo?: string;
}

const { 
  id, 
  gradientFrom = "#ff2a00", 
  gradientTo = "#800000" 
} = Astro.props;
---

<section class="relative w-full bg-[#050505] flex items-center justify-center py-20 px-6 md:px-12 z-50">
  <div class="max-w-5xl mx-auto">
    <p 
      id={id} 
      class="reveal-text text-2xl md:text-4xl lg:text-[2.75rem] font-bold tracking-tight leading-tight text-transparent bg-clip-text"
      style={`--grad-from: ${gradientFrom}; --grad-to: ${gradientTo};`}
    >
      <slot />
    </p>
  </div>
</section>

<style>
  .reveal-text {
    background-image: linear-gradient(
      to bottom,
      var(--grad-from) 0%,     
      var(--grad-to) 40%,    
      #222222 50%,    
      #222222 100%    
    );
    background-size: 100% 200%;
    background-position: 0% 100%; 
    -webkit-background-clip: text;
    background-clip: text;
    transition: background-position 0.1s linear;
  }
</style>