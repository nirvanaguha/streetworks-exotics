---
interface Props {
  id: string;
  gradientFrom: string;
  gradientTo: string;
  text: string;
}

const { id, gradientFrom, gradientTo, text } = Astro.props;
const words = text.split(" ");
---

<section
  class="w-full py-24 md:py-40 px-6 md:px-12 flex items-center justify-center relative z-20"
>
  <div class="max-w-5xl mx-auto text-center">
    <p
      id={id}
      class="text-3xl md:text-5xl lg:text-[3.5rem] font-bold tracking-tight leading-snug md:leading-[1.1]"
      style={`
        /* Creates a tight, looping gradient */
        background: linear-gradient(to right, ${gradientFrom} 0%, ${gradientTo} 50%, ${gradientFrom} 100%); 
        background-size: 200% 100%;
        -webkit-background-clip: text; 
        -webkit-text-fill-color: transparent;
        color: transparent;
      `}
    >
      {words.map((word) => <span class="reveal-word opacity-20">{word} </span>)}
    </p>
  </div>
</section>
