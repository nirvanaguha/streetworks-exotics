const directGoogleMapsLink = "https://www.google.com/maps/search/?api=1&query=StreetWorks+Exotics,+600+Hickory+St,+Pewaukee,+WI+53072";
---

<section id="contact-section" class="relative w-full min-h-screen bg-[#050505] text-white pt-32 pb-24 z-30">
  
  <div class="max-w-7xl mx-auto px-6 md:px-12 w-full grid grid-cols-1 lg:grid-cols-2 gap-16 lg:gap-24">
    
    <div class="flex flex-col items-start justify-center">
      <h2 class="text-6xl md:text-8xl font-bold tracking-tighter uppercase leading-[0.85] mb-8 text-yellow-500">
        Visit<br/>The Shop.
      </h2>
      
      <p class="text-xl md:text-2xl text-white/70 font-light leading-relaxed mb-12 max-w-lg">
        We believe the best way to start a build is a conversation. Stop by to see current restorations, meet the craftsmen, and discuss your vision.
      </p>

      <div class="flex flex-col gap-6 mb-12 text-lg md:text-xl font-light">
        <a href={directGoogleMapsLink} target="_blank" rel="noopener noreferrer" class="group flex items-start gap-4 hover:text-yellow-500 transition-colors">
          <svg class="w-6 h-6 mt-1 shrink-0 opacity-50 group-hover:opacity-100 transition-opacity" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
          <span class="leading-relaxed">
            <strong class="font-bold">StreetWorks Exotics</strong><br/>
            600 Hickory St<br/>
            Pewaukee, WI 53072<br/>
            United States
          </span>
        </a>

        <a href="tel:+12625470052" class="group flex items-center gap-4 hover:text-yellow-500 transition-colors">
          <svg class="w-6 h-6 shrink-0 opacity-50 group-hover:opacity-100 transition-opacity" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path></svg>
          <span>+1 262-547-0052</span>
        </a>

        <a href="mailto:streetworkshotrods@gmail.com" class="group flex items-center gap-4 hover:text-yellow-500 transition-colors">
          <svg class="w-6 h-6 shrink-0 opacity-50 group-hover:opacity-100 transition-opacity" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg>
          <span>streetworkshotrods@gmail.com</span>
        </a>
      </div>

      <div class="flex flex-wrap items-center gap-4">
        <a href={directGoogleMapsLink} target="_blank" rel="noopener noreferrer" class="px-8 py-4 bg-yellow-500 text-black rounded-full hover:bg-white transition-colors font-bold uppercase tracking-widest text-sm shadow-lg shadow-yellow-500/20">
          Get Directions
        </a>
        <a href="tel:+12625470052" class="px-8 py-4 border border-white/30 text-white rounded-full hover:bg-white hover:text-black transition-colors font-bold uppercase tracking-widest text-sm shadow-lg">
          Call the Shop
        </a>
      </div>
    </div>

    <div class="flex flex-col justify-center">
      
      <div class="mb-16">
        <h3 class="text-sm font-mono text-white/50 uppercase tracking-[0.3em] mb-6">Our Digital Garage</h3>
        <div class="flex items-center gap-6">
          {socialLinks.map((social) => (
            <a 
              href={social.url} 
              target="_blank" 
              rel="noopener noreferrer" 
              aria-label={social.name}
              class="w-14 h-14 rounded-full border border-white/20 flex items-center justify-center hover:bg-yellow-500 hover:text-black hover:border-yellow-500 transition-all duration-300 shadow-xl"
            >
              <svg class="w-6 h-6 fill-current" viewBox="0 0 24 24"><path d={social.icon}></path></svg>
            </a>
          ))}
        </div>
      </div>

      <div class="bg-[#111] border border-white/10 p-8 md:p-12 rounded-2xl shadow-2xl">
        <h3 class="text-3xl font-serif italic mb-2">Can't make it in?</h3>
        <p class="text-white/50 font-light mb-8">Drop us a line and we'll reach out.</p>
        
        <form class="flex flex-col gap-6">
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <input type="text" placeholder="Name" class="w-full bg-black/50 border border-white/20 rounded-lg px-4 py-3 text-white placeholder-white/30 focus:outline-none focus:border-yellow-500 transition-colors" />
            <input type="email" placeholder="Email" class="w-full bg-black/50 border border-white/20 rounded-lg px-4 py-3 text-white placeholder-white/30 focus:outline-none focus:border-yellow-500 transition-colors" />
          </div>
          <textarea placeholder="Tell us about your project..." rows="4" class="w-full bg-black/50 border border-white/20 rounded-lg px-4 py-3 text-white placeholder-white/30 focus:outline-none focus:border-yellow-500 transition-colors resize-none"></textarea>
          <button type="submit" class="w-full px-8 py-4 bg-white text-black rounded-lg hover:bg-yellow-500 transition-colors font-bold uppercase tracking-widest text-sm mt-2">
            Send Message
          </button>
        </form>
      </div>

    </div>

  </div>
</section>

<style>
  .perspective-1000 {
    perspective: 1000px;
  }
  .transform-style-3d {
    transform-style: preserve-3d;
  }
  .backface-hidden {
    backface-visibility: hidden;
    -webkit-backface-visibility: hidden;
  }
  .rotate-y-180 {
    transform: rotateY(180deg);
  }
  .is-flipped {
    transform: rotateY(180deg);
  }
</style>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const flipper = document.getElementById('form-flipper');
  const resetBtn = document.getElementById('reset-form');

  if (form && flipper) {
    form.addEventListener('submit', (e) => {
      e.preventDefault(); 
      // NOTE: Insert your fetch() or backend API call here. 
      // For now, it instantly triggers the UI flip.
      flipper.classList.add('is-flipped');
    });
  }

  if (resetBtn && flipper && form) {
    resetBtn.addEventListener('click', () => {
      flipper.classList.remove('is-flipped');
      setTimeout(() => form.reset(), 500); // Clears the form while it's hidden on the back
    });
  }
</script>