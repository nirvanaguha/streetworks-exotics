---
---

<section id="contact-section" class="relative w-full min-h-screen bg-[#050505] flex items-center py-32 px-6 md:px-12 z-50 overflow-hidden">
  
  <div class="absolute top-1/2 right-0 -translate-y-1/2 w-3/4 h-3/4 bg-yellow-500/5 blur-[150px] rounded-full pointer-events-none"></div>

  <div class="max-w-7xl mx-auto w-full grid grid-cols-1 lg:grid-cols-2 gap-20 lg:gap-32 items-start relative z-10">
    
    <div class="flex flex-col gap-10">
      <div>
        <h2 class="text-5xl md:text-7xl font-bold tracking-tighter uppercase leading-[0.9] text-white">
          Commission <br/> <span class="text-yellow-500">A Masterpiece.</span>
        </h2>
        <p class="text-xl text-white/60 font-light mt-8 leading-relaxed max-w-md">
          Have a question about our work? Wondering how we can restore your vehicle to its original glory? Fill out the details below and our lead restorers will be in touch.
        </p>
      </div>

      <div class="flex flex-col gap-4 mt-8">
        <div class="flex flex-col">
          <span class="text-xs uppercase tracking-widest text-white/40 font-bold mb-1">Email Us</span>
          <a href="mailto:info@streetworksexotics.com" class="text-xl text-white hover:text-yellow-500 transition-colors">info@streetworksexotics.com</a>
        </div>
        <div class="flex flex-col mt-4">
          <span class="text-xs uppercase tracking-widest text-white/40 font-bold mb-1">Call Us</span>
          <a href="tel:+12625550198" class="text-xl text-white hover:text-yellow-500 transition-colors">+1 (262) 555-0198</a>
        </div>
      </div>
    </div>

    <div class="relative w-full perspective-1000">
      
      <div id="form-flipper" class="relative w-full transition-transform duration-[1200ms] ease-[cubic-bezier(0.23,1,0.32,1)] transform-style-3d">
        
        <div class="w-full bg-[#0a0a0a] p-8 md:p-12 rounded-2xl border border-white/5 shadow-2xl backface-hidden">
          <form id="contact-form" class="flex flex-col gap-12">
            
            <div class="grid grid-cols-1 md:grid-cols-2 gap-12">
              <div class="relative group">
                <input type="text" id="firstName" name="firstName" required class="w-full bg-transparent border-b border-white/20 pb-3 text-lg text-white placeholder-transparent focus:outline-none focus:border-yellow-500 transition-colors peer" placeholder="First Name" />
                <label for="firstName" class="absolute left-0 -top-6 text-xs font-bold uppercase tracking-widest text-white/40 transition-all peer-placeholder-shown:text-base peer-placeholder-shown:text-white/40 peer-placeholder-shown:top-0 peer-focus:-top-6 peer-focus:text-xs peer-focus:text-yellow-500 cursor-text">First Name *</label>
              </div>
              
              <div class="relative group">
                <input type="text" id="lastName" name="lastName" required class="w-full bg-transparent border-b border-white/20 pb-3 text-lg text-white placeholder-transparent focus:outline-none focus:border-yellow-500 transition-colors peer" placeholder="Last Name" />
                <label for="lastName" class="absolute left-0 -top-6 text-xs font-bold uppercase tracking-widest text-white/40 transition-all peer-placeholder-shown:text-base peer-placeholder-shown:text-white/40 peer-placeholder-shown:top-0 peer-focus:-top-6 peer-focus:text-xs peer-focus:text-yellow-500 cursor-text">Last Name *</label>
              </div>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-12">
              <div class="relative group">
                <input type="tel" id="phone" name="phone" required class="w-full bg-transparent border-b border-white/20 pb-3 text-lg text-white placeholder-transparent focus:outline-none focus:border-yellow-500 transition-colors peer" placeholder="Phone" />
                <label for="phone" class="absolute left-0 -top-6 text-xs font-bold uppercase tracking-widest text-white/40 transition-all peer-placeholder-shown:text-base peer-placeholder-shown:text-white/40 peer-placeholder-shown:top-0 peer-focus:-top-6 peer-focus:text-xs peer-focus:text-yellow-500 cursor-text">Phone *</label>
              </div>
              
              <div class="relative group">
                <input type="email" id="email" name="email" required class="w-full bg-transparent border-b border-white/20 pb-3 text-lg text-white placeholder-transparent focus:outline-none focus:border-yellow-500 transition-colors peer" placeholder="Email" />
                <label for="email" class="absolute left-0 -top-6 text-xs font-bold uppercase tracking-widest text-white/40 transition-all peer-placeholder-shown:text-base peer-placeholder-shown:text-white/40 peer-placeholder-shown:top-0 peer-focus:-top-6 peer-focus:text-xs peer-focus:text-yellow-500 cursor-text">Email *</label>
              </div>
            </div>

            <div class="relative group mt-4">
              <textarea id="message" name="message" rows="4" required class="w-full bg-transparent border-b border-white/20 pb-3 text-lg text-white placeholder-transparent focus:outline-none focus:border-yellow-500 transition-colors peer resize-none" placeholder="Tell us about your car"></textarea>
              <label for="message" class="absolute left-0 -top-6 text-xs font-bold uppercase tracking-widest text-white/40 transition-all peer-placeholder-shown:text-base peer-placeholder-shown:text-white/40 peer-placeholder-shown:top-0 peer-focus:-top-6 peer-focus:text-xs peer-focus:text-yellow-500 cursor-text">Please tell us about your car *</label>
            </div>

            <button type="submit" class="mt-8 self-start px-10 py-4 bg-white text-black font-bold uppercase tracking-widest text-sm hover:bg-yellow-500 transition-colors duration-300">
              Send Request
            </button>

          </form>
        </div>

        <div class="absolute inset-0 w-full h-full bg-[#0a0a0a] p-8 md:p-12 rounded-2xl border border-white/5 shadow-2xl backface-hidden rotate-y-180 flex flex-col items-center justify-center text-center">
          
          <div class="w-24 h-24 rounded-full border border-yellow-500/30 bg-yellow-500/10 flex items-center justify-center mb-8 shadow-[0_0_50px_rgba(234,179,8,0.15)]">
            <svg class="w-12 h-12 text-yellow-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
          </div>
          
          <h3 class="text-4xl font-bold tracking-tighter uppercase text-white mb-4">Request Received</h3>
          <p class="text-lg text-white/60 font-light leading-relaxed max-w-sm mx-auto">
            We've received your inquiry. Our lead restorers will be in touch shortly.
          </p>
          
          <button id="reset-form" type="button" class="mt-12 text-xs font-bold uppercase tracking-[0.2em] text-white/30 hover:text-white transition-colors border-b border-transparent hover:border-white pb-1">
            Submit Another Request
          </button>
        </div>

      </div>
    </div>

  </div>
</section>

<style>
  .perspective-1000 {
    perspective: 1000px;
  }
  .transform-style-3d {
    transform-style: preserve-3d;
  }
  .backface-hidden {
    backface-visibility: hidden;
    -webkit-backface-visibility: hidden;
  }
  .rotate-y-180 {
    transform: rotateY(180deg);
  }
  .is-flipped {
    transform: rotateY(180deg);
  }
</style>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const flipper = document.getElementById('form-flipper');
  const resetBtn = document.getElementById('reset-form');

  if (form && flipper) {
    form.addEventListener('submit', (e) => {
      e.preventDefault(); 
      // NOTE: Insert your fetch() or backend API call here. 
      // For now, it instantly triggers the UI flip.
      flipper.classList.add('is-flipped');
    });
  }

  if (resetBtn && flipper && form) {
    resetBtn.addEventListener('click', () => {
      flipper.classList.remove('is-flipped');
      setTimeout(() => form.reset(), 500); // Clears the form while it's hidden on the back
    });
  }
</script>