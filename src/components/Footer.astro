---
const currentYear = new Date().getFullYear();
---

<footer class="relative w-full bg-[#050505] border-t border-white/5 pt-12 pb-8 px-6 md:px-12 z-30">
  <div class="max-w-7xl mx-auto flex flex-col lg:flex-row justify-between items-center lg:items-end gap-8">
    
    <div class="flex flex-col items-center lg:items-start gap-3">
      <span class="text-2xl font-bold tracking-tighter uppercase text-white">StreetWorks</span>
      <p class="text-white/40 text-xs font-mono uppercase tracking-[0.2em]">
        &copy; {currentYear} StreetWorks Exotics. All rights reserved.
      </p>
    </div>

    <nav class="flex flex-wrap justify-center gap-6 md:gap-10 text-xs font-bold uppercase tracking-[0.2em] text-white/50">
      <a href="#" class="hover:text-yellow-500 hover:-translate-y-1 transition-all duration-300">Home</a>
      <a href="#services-master-container" class="hover:text-yellow-500 hover:-translate-y-1 transition-all duration-300">Services</a>
      <a href="#" class="hover:text-yellow-500 hover:-translate-y-1 transition-all duration-300">Portfolio</a>
      <a href="#contact-section" class="hover:text-yellow-500 hover:-translate-y-1 transition-all duration-300">Contact</a>
    </nav>

    <div class="flex gap-6 text-xs font-light text-white/30 hover:text-white/70 transition-colors">
      <a href="/privacy" class="hover:text-white transition-colors">Privacy Policy</a>
      <a href="/terms" class="hover:text-white transition-colors">Terms of Service</a>
    </div>

  </div>
</footer>