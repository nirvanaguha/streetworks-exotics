---
interface Props {
  title: string;
  description: string;
  bgImgUrl: string;
  serviceUrl: string;
  bookingUrl?: string;
  galleryRow1: string[];
  galleryRow2: string[];
}

const {
  title,
  description,
  bgImgUrl,
  serviceUrl,
  bookingUrl = "#",
  galleryRow1,
  galleryRow2
} = Astro.props;
---

<section class="service-section sticky top-0 w-full h-screen overflow-hidden flex flex-col justify-center pt-32 pb-4 z-40 bg-[#050505]">
  
  <div class="service-bg-layer absolute inset-0 z-0 pointer-events-none overflow-hidden">
    <img 
      src={bgImgUrl} 
      alt={title} 
      class="service-bg absolute inset-0 w-full h-[120%] -top-[10%] object-cover opacity-70" 
    />
    <div class="absolute inset-0 bg-gradient-to-t from-[#050505] via-[#050505]/80 to-[#050505]/30"></div>
  </div>

  <div class="service-ui-layer relative z-10 w-full flex flex-col gap-8 md:gap-12">
    
    <div class="max-w-7xl mx-auto px-6 md:px-12 w-full flex flex-col lg:flex-row justify-between items-start lg:items-end gap-6">
      <div class="max-w-3xl">
        <h2 class="text-5xl md:text-7xl lg:text-[5.5rem] font-bold tracking-tighter uppercase leading-[0.9] text-white drop-shadow-2xl">{title}</h2>
        <p class="text-lg md:text-2xl text-white/70 font-light mt-4 leading-relaxed">{description}</p>
      </div>
      
      <div class="flex items-center gap-4 shrink-0 pointer-events-auto">
        <a href={serviceUrl} class="px-6 py-3 border border-white/30 rounded-full hover:bg-white hover:text-black transition-colors font-bold uppercase tracking-widest text-xs shadow-lg">
          See Service
        </a>
        <a href={bookingUrl} class="px-6 py-3 bg-white text-black rounded-full hover:bg-yellow-500 transition-colors font-bold uppercase tracking-widest text-xs shadow-lg shadow-white/10">
          Book Now
        </a>
      </div>
    </div>

    <div class="w-full overflow-hidden mask-carousel relative pointer-events-auto">
      <div class="flex flex-col gap-4 md:gap-6">
        
        <div class="flex gap-4 md:gap-6 w-max animate-marquee hover:[animation-play-state:paused]">
          {[...galleryRow1, ...galleryRow1].map((img) => (
            <div class="h-32 md:h-48 lg:h-56 shrink-0 rounded-xl overflow-hidden bg-white/5 border border-white/10">
              <img src={img} alt="Service Detail" class="h-full w-auto object-cover hover:scale-105 transition-transform duration-500 cursor-pointer" />
            </div>
          ))}
        </div>

        <div class="flex gap-4 md:gap-6 w-max animate-marquee-reverse hover:[animation-play-state:paused]">
          {[...galleryRow2, ...galleryRow2].map((img) => (
            <div class="h-32 md:h-48 lg:h-56 shrink-0 rounded-xl overflow-hidden bg-white/5 border border-white/10">
              <img src={img} alt="Service Detail" class="h-full w-auto object-cover hover:scale-105 transition-transform duration-500 cursor-pointer" />
            </div>
          ))}
        </div>

      </div>
    </div>

  </div>
</section>

<style>
  .mask-carousel {
    mask-image: linear-gradient(to right, transparent, black 10%, black 90%, transparent);
    -webkit-mask-image: linear-gradient(to right, transparent, black 10%, black 90%, transparent);
  }
  
  @keyframes marquee {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }
  
  .animate-marquee {
    animation: marquee 40s linear infinite;
  }
  
  .animate-marquee-reverse {
    animation: marquee 45s linear infinite reverse;
  }
</style>