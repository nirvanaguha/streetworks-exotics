---
const awards = [
  {
    name: "Pebble Beach Concours d'Elegance",
    logo: "https://www.pebblebeachconcours.net/wp-content/themes/pbc-wp-theme-child/library/images/logo.png"
  },
  {
    name: "The Amelia",
    logo: "https://cdn.prod.website-files.com/68c03ec0d6be7142be9855ae/68db1f4c0a9bb199d48eb997_Amelia-horizontal-revised.svg"
  },
  {
    name: "Concorso d’Eleganza Villa d’Este",
    logo: "https://www.concorsodeleganzavilladeste.com/assets/concorso/VdE_Logo_white.svg"
  }
];
---

<div id="awards-section" class="absolute inset-0 z-40 flex flex-col justify-end px-6 md:px-12 invisible pointer-events-none pb-[8vh] md:pb-[12vh]">
  <div class="max-w-7xl w-full mx-auto grid grid-cols-1 md:grid-cols-12 gap-10 md:gap-0 items-start">
    
    <div class="md:col-span-5 flex flex-col">
      <h2 class="text-4xl md:text-5xl lg:text-[4rem] font-bold tracking-tighter leading-[0.9] drop-shadow-lg text-left">
        We don’t like to toot our own horn, <span class="text-white/40 italic font-serif font-light tracking-normal block mt-2">but…</span>
      </h2>
    </div>

    <div class="md:col-span-6 md:col-start-7 flex flex-col gap-10 md:pt-4">
      <p class="text-base md:text-xl text-white/60 font-light leading-relaxed text-left max-w-lg">
        Our award winning restorations speak for themselves. We have experienced success worldwide including The Pebble Beach Concours d’Elegance, Amelia Island Concours d’Elegance and Concorso d’Eleganza Villa d’Este in Cernobbio, Italy.
      </p>

      <div class="flex flex-row flex-wrap items-center justify-start gap-8 md:gap-12 w-full pointer-events-auto">
        {awards.map((award) => (
          <img 
            src={award.logo} 
            alt={award.name} 
            class="h-5 md:h-8 w-auto object-contain opacity-40 grayscale hover:grayscale-0 hover:opacity-100 hover:-translate-y-1 transition-all duration-500 cursor-pointer drop-shadow-md"
          />
        ))}
      </div>
    </div>

  </div>
</div>