<header id="main-navbar" class="fixed top-0 left-0 w-full z-[100] px-6 md:px-12 py-6 flex justify-between items-center pointer-events-none">
  
  <div id="nav-bg" class="absolute inset-0 bg-[#050505]/70 backdrop-blur-md border-b border-white/10 opacity-0 transition-opacity duration-500 pointer-events-auto -z-10"></div>

  <a href="#" class="text-xl md:text-2xl font-black tracking-tighter uppercase text-white drop-shadow-md pointer-events-auto hover:text-yellow-500 transition-colors">
    StreetWorks
  </a>

  <a href="#contact-section" class="px-6 py-3 bg-white text-black font-bold uppercase tracking-widest text-xs hover:bg-yellow-500 transition-colors duration-300 pointer-events-auto rounded-sm shadow-2xl">
    Book Now
  </a>

</header>

<script>
  // Simple scroll watcher to trigger the frosted glass
  const navBg = document.getElementById('nav-bg');
  
  if (navBg) {
    window.addEventListener('scroll', () => {
      if (window.scrollY > 50) {
        navBg.classList.remove('opacity-0');
        navBg.classList.add('opacity-100');
      } else {
        navBg.classList.add('opacity-0');
        navBg.classList.remove('opacity-100');
      }
    });
  }
</script>