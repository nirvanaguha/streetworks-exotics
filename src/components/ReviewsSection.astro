---
const reviews = [
  {
    name: "Brian Roell",
    text: "On my Corvette, their team repaired the leather on my dash, A-pillar, and center console. They also restored the headliner and door panel map pockets on my Mustang Cobra. I am not an easy one to please, but both jobs were done with outstanding craftsmanship and attention to detail. The results honestly exceeded my expectations. The entire process was professional, timely, and hassle-free, and it’s clear they take real pride in their work.",
    imgUrl: "/Corvette-Testimonial.jpg" 
  },
  {
    name: "Matt Protz",
    text: "This shop is amazing! The owner and all the staff are exceptional! Very friendly, and their skills are unmatched! If you have any need of professional car building or customizations, this is THE PLACE! Dream cars are made and perfected here.",
    imgUrl: "/Testimonial-Matt.jpg" 
  },
  {
    name: "John Zick",
    text: "They built my 30 Ford Coupe, and did an excellent job.",
    imgUrl: "/Ford-Coupe-60.jpg" 
  }
];
---

<section id="reviews-container" class="relative w-full h-[400dvh] z-[15] -mt-[100dvh]">
  
  <div class="sticky top-0 w-full h-[100dvh] overflow-hidden flex items-center pt-16 md:pt-0">
    
    <div id="reviews-fade-layer" class="opacity-0 invisible w-full h-full absolute inset-0 flex items-center justify-start z-10">
      
      <div class="absolute inset-0 w-full h-full pointer-events-none z-20">
        <div class="absolute top-0 left-0 w-full h-24 md:h-32 bg-gradient-to-b from-black to-transparent"></div>
        <div class="absolute bottom-0 left-0 w-full h-24 md:h-32 bg-gradient-to-t from-black to-transparent"></div>
      </div>

      <div id="reviews-track" class="flex w-[300vw] h-full items-center relative z-10">
        
        {reviews.map((review) => (
          <div class="review-panel w-[100vw] h-full flex flex-col md:flex-row items-center justify-center px-6 md:px-12 lg:px-24 gap-4 md:gap-16 shrink-0">
            
            <div class="w-full md:w-1/2 max-w-2xl flex flex-col items-start text-left">
              <div class="flex gap-1 md:gap-2 text-yellow-500 mb-4 md:mb-8">
                {[1, 2, 3, 4, 5].map(() => (
                  <svg class="w-4 h-4 md:w-6 md:h-6 drop-shadow-md" fill="currentColor" viewBox="0 0 20 20">
                    <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"></path>
                  </svg>
                ))}
              </div>
              
              <p class="text-base sm:text-lg md:text-2xl lg:text-3xl font-serif italic text-white/90 leading-relaxed mb-4 md:mb-8">"{review.text}"</p>
              
              <span class="text-white font-bold uppercase tracking-[0.2em] text-xs md:text-base">— {review.name}</span>
            </div>

            <div class="w-full md:w-1/2 h-[25dvh] sm:h-[30dvh] md:h-[50dvh] max-w-xl rounded-xl overflow-hidden relative shadow-[0_0_50px_rgba(0,0,0,0.5)] border border-white/10 shrink-0">
              <img src={review.imgUrl} alt="Customer Review Image" class="w-full h-full object-cover" />
              <div class="absolute inset-0 bg-gradient-to-t from-black/50 to-transparent"></div>
            </div>

          </div>
        ))}

      </div>
    </div>
  </div>
</section>